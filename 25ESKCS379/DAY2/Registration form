<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>College Admission Form</title>
    <link rel="stylesheet" href="style.css">
</head>

<body>

<div class="container">

    <h1>College Admission Form</h1>
    <p>Please fill all the details carefully.</p>

    <form id="admissionForm">

        <label>Full Name</label>
        <input type="text" id="name" placeholder="Enter your full name" required>

        <label>Email</label>
        <input type="email" id="email" placeholder="Enter your email" required>

        <label>Phone Number</label>
        <input type="tel" id="phone" maxlength="10" placeholder="10-digit phone number" required>

        <label>Gender</label>

        <div class="gender">
            <input type="radio" name="gender" required> Male
            <input type="radio" name="gender"> Female
            <input type="radio" name="gender"> Other
        </div>

        <label>Date of Birth</label>
        <input type="date" required>

        <label>Course</label>

        <select required>
            <option value="">Select Course</option>
            <option>B.Tech</option>
            <option>BCA</option>
            <option>BBA</option>
            <option>B.Sc</option>
            <option>BA</option>
        </select>

        <label>Department</label>

        <select required>
            <option value="">Select Department</option>
            <option>Computer Science</option>
            <option>Information Technology</option>
            <option>Electronics</option>
            <option>Mechanical</option>
            <option>Civil</option>
        </select>

        <label>12th Percentage</label>
        <input type="number" id="percentage" min="0" max="100" placeholder="Enter Percentage" required>

        <label>Address</label>

        <textarea rows="4" placeholder="Enter your address" required></textarea>

        <label>Password</label>
        <input type="password" id="password" required>

        <label>Confirm Password</label>
        <input type="password" id="confirm" required>

        <input type="submit" value="Submit Application">

        <input type="reset" value="Reset">

    </form>

</div>

<script src="script.js"></script>

</body>
</html>